# ============================================================
# SAGA Platform — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores
# ============================================================

# ========== SHADOW AI MODULE ==========

# Token GitHub com acesso de leitura aos repositórios da organização
GITHUB_TOKEN=ghp_your_token_here

# Token GitLab (opcional)
GITLAB_TOKEN=

# Nome da organização GitHub/GitLab alvo
TARGET_ORGANIZATION=my_organization

# ========== AI-DSRM MODULE ==========

# Credenciais do banco de dados PostgreSQL
DSRM_DB_PASSWORD=dsrm_dev_password_2024

# JWT Secret para autenticação (use um valor seguro em produção)
JWT_SECRET=dev-secret-nao-usar-em-producao-change-me

# GitHub App (necessário para integração real)
GITHUB_APP_ID=12345
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# ========== PORTAL ==========

# URLs dos módulos (usadas pelo portal para redirecionar)
VITE_SHADOW_AI_URL=http://localhost:5173
VITE_DSRM_URL=http://localhost:3001
